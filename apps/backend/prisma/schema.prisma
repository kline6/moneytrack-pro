generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum TransactionType {
  EXPENSE
  INCOME
}

enum BudgetPeriodType {
  MONTHLY
  WEEKLY
}

enum SyncStatus {
  PENDING
  SUCCESS
  FAILED
  CONFLICT
}

model User {
  id            String      @id @default(uuid())
  email         String      @unique @db.VarChar(254)
  passwordHash  String      @map("password_hash") @db.VarChar(255)
  displayName   String      @map("display_name") @db.VarChar(50)
  status        UserStatus  @default(ACTIVE)
  lastLoginAt   DateTime?   @map("last_login_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  categories    Category[]
  transactions  Transaction[]
  budgets       Budget[]
  attachments   Attachment[]
  syncEvents    SyncEvent[]
  merchantRules MerchantRule[]

  @@map("users")
}

model Category {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  name            String           @db.VarChar(60)
  icon            String           @db.VarChar(60)
  color           String           @db.VarChar(20)
  sortOrder       Int              @default(0) @map("sort_order")
  isSystem        Boolean          @default(false) @map("is_system")
  transactionType TransactionType  @map("transaction_type")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  budgets         Budget[]
  merchantRules   MerchantRule[]

  @@unique([userId, name, transactionType], map: "uq_categories_user_name_type")
  @@index([userId, sortOrder], map: "idx_categories_user_sort")
  @@index([userId, transactionType], map: "idx_categories_user_type")
  @@map("categories")
}

model Transaction {
  id              String           @id @default(uuid())
  userId          String           @map("user_id")
  categoryId      String           @map("category_id")
  type            TransactionType
  amount          Int
  currencyCode    String           @default("CNY") @map("currency_code") @db.VarChar(3)
  occurredAt      DateTime         @map("occurred_at")
  title           String           @db.VarChar(120)
  note            String?          @db.VarChar(500)
  merchant        String?          @db.VarChar(120)
  tags            Json?
  sourceDeviceId  String?          @map("source_device_id") @db.VarChar(64)
  clientTxnId     String           @unique @map("client_txn_id") @db.VarChar(64)
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  deletedAt       DateTime?        @map("deleted_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  attachments     Attachment[]
  syncEvents      SyncEvent[]

  @@index([userId, occurredAt], map: "idx_transactions_user_occurred_at")
  @@index([userId, categoryId, occurredAt], map: "idx_transactions_user_category_time")
  @@index([userId, type, occurredAt], map: "idx_transactions_user_type_time")
  @@map("transactions")
}

model Budget {
  id            String           @id @default(uuid())
  userId        String           @map("user_id")
  periodType    BudgetPeriodType @map("period_type")
  year          Int
  month         Int
  weekStart     DateTime?        @map("week_start")
  categoryId    String?          @map("category_id")
  amount        Int
  currencyCode  String           @default("CNY") @map("currency_code") @db.VarChar(3)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  deletedAt     DateTime?        @map("deleted_at")

  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  category      Category?        @relation(fields: [categoryId], references: [id])

  @@unique([userId, periodType, year, month, categoryId], map: "uq_budgets_user_period_scope")
  @@index([userId, year, month], map: "idx_budgets_user_year_month")
  @@map("budgets")
}

model Attachment {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  transactionId String     @map("transaction_id")
  storageKey    String     @map("storage_key") @db.VarChar(512)
  originalName  String     @map("original_name") @db.VarChar(255)
  mimeType      String     @map("mime_type") @db.VarChar(127)
  sizeBytes     Int        @map("size_bytes")
  createdAt     DateTime   @default(now()) @map("created_at")
  deletedAt     DateTime?  @map("deleted_at")

  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([transactionId], map: "idx_attachments_transaction")
  @@map("attachments")
}

model SyncEvent {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  deviceId      String      @map("device_id") @db.VarChar(64)
  clientTxnId   String      @map("client_txn_id") @db.VarChar(64)
  entityType    String      @map("entity_type") @db.VarChar(32)
  entityId      String      @map("entity_id")
  operation     String      @db.VarChar(16)
  payload       Json
  status        SyncStatus  @default(PENDING)
  retryCount    Int         @default(0) @map("retry_count")
  processedAt   DateTime?   @map("processed_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction? @relation(fields: [entityId], references: [id], onDelete: SetNull)

  @@unique([userId, clientTxnId], map: "uq_sync_events_user_client_txn")
  @@index([userId, status], map: "idx_sync_events_user_status")
  @@map("sync_events")
}

model MerchantRule {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  merchant    String   @db.VarChar(120)
  categoryId  String   @map("category_id")
  weight      Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, merchant], map: "uq_merchant_rules_user_merchant")
  @@index([userId, merchant], map: "idx_merchant_rules_user_merchant")
  @@map("merchant_rules")
}
